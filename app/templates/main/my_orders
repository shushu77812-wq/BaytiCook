<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
<meta charset="UTF-8">
<title>طلباتي</title>

<style>
body{
  margin:0;
  font-family:Tahoma;
  background:#f5f6fa;
  direction:rtl;
  display:flex;
}

.sidebar{
  width:220px;
  background:#1e272e;
  color:white;
  height:100vh;
  padding:30px;
  position:fixed;
  right:0;
  top:0;
}
.sidebar a{
  display:block;
  color:white;
  margin:15px 0;
  text-decoration:none;
}

.content{
  margin-right:240px;
  padding:30px;
  width:100%;
}

.order-box{
  background:white;
  padding:20px;
  border-radius:12px;
  margin-bottom:20px;
  box-shadow:0 4px 15px rgba(0,0,0,0.1);
}

.progress{
  display:flex;
  justify-content:space-between;
  margin-top:15px;
}

.step{
  flex:1;
  text-align:center;
  position:relative;
}

.step::before{
  content:"";
  position:absolute;
  top:10px;
  left:-50%;
  width:100%;
  height:4px;
  background:#ddd;
}

.step:first-child::before{display:none;}

.circle{
  width:20px;
  height:20px;
  border-radius:50%;
  background:#ddd;
  margin:auto;
}

.active .circle{background:#27ae60;}

.label{font-size:12px;margin-top:5px;}

.pending{color:#999;background:#f0f0f0;padding:5px;border-radius:5px;}
.preparing{color:#f39c12;background:#fff3cd;padding:5px;border-radius:5px;}
.delivered{color:#2ecc71;background:#e2f7e2;padding:5px;border-radius:5px;}
</style>
</head>

<body>

<div class="sidebar">
  <h2>👤 حسابي</h2>
  <a href="/">الرئيسية</a>
  <a href="/cart">السلة</a>
  <a href="/my-orders">طلباتي</a> <!-- ✅ تعديل -->
</div>

<div class="content">

<h2>📦 طلباتي</h2>

{% for order in orders %}
<div class="order-box">

  <h3>طلب رقم {{ order.id }}</h3>
  <p>🍳 {{ order.kitchen.kitchen_name }}</p>

  <!-- الحالة -->
  <p class="
    {% if order.status == 'pending' %}pending
    {% elif order.status == 'preparing' %}preparing
    {% elif order.status == 'delivered' %}delivered
    {% endif %}
  ">

    {% if order.status == "pending" %}
      ✅ تم الطلب
    {% elif order.status == "preparing" %}
      🍳 قيد التحضير
    {% elif order.status == "delivered" %}
      🚚 تم التوصيل
    {% endif %}

  </p>

  <p>💰 {{ order.total_price }} ريال</p>

  <!-- الأطباق -->
  <ul>
    {% for item in order.items %}
      <li>{{ item.meal.name }} × {{ item.quantity }}</li>
    {% endfor %}
  </ul>

  <!-- صورة التحويل -->
  {% if order.proof_image %}
    <p>📷 صورة التحويل:</p>
    <img src="{{ url_for('static', filename='uploads/proofs/' + order.proof_image) }}" width="200">
  {% endif %}

  <!-- progress -->
  <div class="progress">

    <div class="step {% if order.status in ['pending','preparing','delivered'] %}active{% endif %}">
      <div class="circle"></div>
      <div class="label">تم الطلب</div>
    </div>

    <div class="step {% if order.status in ['preparing','delivered'] %}active{% endif %}">
      <div class="circle"></div>
      <div class="label">تحضير</div>
    </div>

    <div class="step {% if order.status == 'delivered' %}active{% endif %}">
      <div class="circle"></div>
      <div class="label">تم</div>
    </div>

  </div>

</div>
{% endfor %}

</div>

<script>
setInterval(function(){
    location.reload();
}, 5000);
</script>

</body>
</html>